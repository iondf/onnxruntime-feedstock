From deeb83140459462c7d42990d563f17cbccc6a771 Mon Sep 17 00:00:00 2001
From: Christian Bourjau <christian.bourjau@quantco.com>
Date: Tue, 10 Feb 2026 17:43:42 +0100
Subject: [PATCH 4/4] Remove redundant include paths from custom op test
 targets

After commit e0569fd moved endian.h from core/framework to core/common,
the -I path for core/common causes onnxruntime's endian.h to shadow the
system <endian.h>. This breaks compilation on Linux with glibc 2.17
which is used on conda-forge.

The include paths for core/session and core/common were redundant anyway.
---
 cmake/onnxruntime_unittests.cmake                           | 6 ------
 .../custom_op_get_const_input_test_library/custom_op.cc     | 2 +-
 2 files changed, 1 insertion(+), 7 deletions(-)

diff --git a/cmake/onnxruntime_unittests.cmake b/cmake/onnxruntime_unittests.cmake
index ad6f6eb790..584ed6c6c6 100644
--- a/cmake/onnxruntime_unittests.cmake
+++ b/cmake/onnxruntime_unittests.cmake
@@ -1999,9 +1999,6 @@ if (NOT CMAKE_SYSTEM_NAME STREQUAL "Emscripten" AND (NOT onnxruntime_MINIMAL_BUI
   onnxruntime_add_shared_library_module(custom_op_get_const_input_test_library ${custom_op_get_const_input_test_library_src})
 
   onnxruntime_add_include_to_target(custom_op_get_const_input_test_library onnxruntime_common GTest::gtest GTest::gmock)
-  target_include_directories(custom_op_get_const_input_test_library PRIVATE ${REPO_ROOT}/include/onnxruntime/core/session
-                                                                            ${REPO_ROOT}/include/onnxruntime/core/common)
-
   if(UNIX)
     if (APPLE)
       set(ONNXRUNTIME_CUSTOM_OP_GET_CONST_INPUT_TEST_LIB_LINK_FLAG "-Xlinker -dead_strip")
@@ -2031,9 +2028,6 @@ if (NOT CMAKE_SYSTEM_NAME STREQUAL "Emscripten" AND (NOT onnxruntime_MINIMAL_BUI
   onnxruntime_add_shared_library_module(custom_op_local_function ${custom_op_local_function_test_library_src})
 
   onnxruntime_add_include_to_target(custom_op_local_function onnxruntime_common GTest::gtest GTest::gmock)
-  target_include_directories(custom_op_local_function PRIVATE ${REPO_ROOT}/include/onnxruntime/core/session
-                                                                            ${REPO_ROOT}/include/onnxruntime/core/common)
-
   if(UNIX)
     if (APPLE)
       set(ONNXRUNTIME_CUSTOM_OP_lOCAL_FUNCTION_TEST_LIB_LINK_FLAG "-Xlinker -dead_strip")
diff --git a/onnxruntime/test/testdata/custom_op_get_const_input_test_library/custom_op.cc b/onnxruntime/test/testdata/custom_op_get_const_input_test_library/custom_op.cc
index 08d8bf38d4..e45db22594 100644
--- a/onnxruntime/test/testdata/custom_op_get_const_input_test_library/custom_op.cc
+++ b/onnxruntime/test/testdata/custom_op_get_const_input_test_library/custom_op.cc
@@ -1,7 +1,7 @@
 // Copyright (c) Microsoft Corporation. All rights reserved.
 // Licensed under the MIT License.
 #include "custom_op.h"
-#include "common.h"
+#include "core/common/common.h"
 
 void simple_assert(const bool cond, const std::string& text) {
   if (!cond) {
